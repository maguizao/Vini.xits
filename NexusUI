-- Limpeza da UI (para recriar ou destruir)
function NexusUI.Destroy()
    if NexusUI.ScreenGui then
        NexusUI.ScreenGui:Destroy()
    end
    if NexusUI.NotifyContainer then
        NexusUI.NotifyContainer:Destroy()
    end
    NexusUI.Tabs = {}
    NexusUI.SavedPositions = {}
end

return NexusUI
