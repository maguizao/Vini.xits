local NexusLib = {}

-- Serviços necessários
local CoreGui = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")

local LocalPlayer = Players.LocalPlayer

-- Proteção básica da GUI
local function GetGuiParent()
    if gethui then return gethui() end
    if syn and syn.protect_gui then
        local gui = Instance.new("ScreenGui")
        syn.protect_gui(gui)
        gui.Parent = CoreGui
        return gui
    end
    return CoreGui
end

local GuiParent = GetGuiParent()

-- ==========================================
-- SISTEMA DE NOTIFICAÇÃO
-- ==========================================
function NexusLib:Notify(title, text, duration)
    duration = duration or 3
    
    -- Verifica se já existe um container de notificações
    local notifyGui = GuiParent:FindFirstChild("NexusNotifications")
    if not notifyGui then
        notifyGui = Instance.new("ScreenGui")
        notifyGui.Name = "NexusNotifications"
        notifyGui.Parent = GuiParent
        
        local container = Instance.new("Frame")
        container.Name = "Container"
        container.Size = UDim2.new(0, 300, 1, 0)
        container.Position = UDim2.new(1, -320, 0, 0)
        container.BackgroundTransparency = 1
        container.Parent = notifyGui
        
        local listLayout = Instance.new("UIListLayout")
        listLayout.Parent = container
        listLayout.SortOrder = Enum.SortOrder.LayoutOrder
        listLayout.VerticalAlignment = Enum.VerticalAlignment.Bottom
        listLayout.Padding = UDim.new(0, 10)
    end
    
    local container = notifyGui.Container
    
    -- Cria a notificação
    local notif = Instance.new("Frame")
    notif.Size = UDim2.new(1, 0, 0, 60)
    notif.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    notif.BorderSizePixel = 0
    notif.Parent = container
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = notif
    
    local titleLbl = Instance.new("TextLabel")
    titleLbl.Size = UDim2.new(1, -20, 0, 20)
    titleLbl.Position = UDim2.new(0, 10, 0, 5)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text = title
    titleLbl.TextColor3 = Color3.fromRGB(255, 255, 255)
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.Font = Enum.Font.GothamBold
    titleLbl.TextSize = 14
    titleLbl.Parent = notif
    
    local textLbl = Instance.new("TextLabel")
    textLbl.Size = UDim2.new(1, -20, 0, 30)
    textLbl.Position = UDim2.new(0, 10, 0, 25)
    textLbl.BackgroundTransparency = 1
    textLbl.Text = text
    textLbl.TextColor3 = Color3.fromRGB(200, 200, 200)
    textLbl.TextXAlignment = Enum.TextXAlignment.Left
    textLbl.TextYAlignment = Enum.TextYAlignment.Top
    textLbl.TextWrapped = true
    textLbl.Font = Enum.Font.Gotham
    textLbl.TextSize = 12
    textLbl.Parent = notif

    -- Animação de entrada
    notif.Position = UDim2.new(1, 50, 0, 0)
    TweenService:Create(notif, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Position = UDim2.new(0, 0, 0, 0)}):Play()
    
    -- Destrói após o tempo
    task.spawn(function()
        task.wait(duration)
        local fade = TweenService:Create(notif, TweenInfo.new(0.5), {BackgroundTransparency = 1})
        TweenService:Create(titleLbl, TweenInfo.new(0.5), {TextTransparency = 1}):Play()
        TweenService:Create(textLbl, TweenInfo.new(0.5), {TextTransparency = 1}):Play()
        fade:Play()
        fade.Completed:Wait()
        notif:Destroy()
    end)
end

-- ==========================================
-- CRIAÇÃO DA JANELA PRINCIPAL
-- ==========================================
function NexusLib:CreateWindow(config)
    local WindowName = config.Name or "Nexus Hub"
    local LogoImage = config.Logo or "rbxassetid://1234567890" -- Substitua pelo ID do seu "N"

    local NexusGui = Instance.new("ScreenGui")
    NexusGui.Name = "NexusMainGui"
    NexusGui.ResetOnSpawn = false
    NexusGui.Parent = GuiParent

    -- BOTÃO TOGGLE (O "N" ImagemButton)
    local ToggleBtn = Instance.new("ImageButton")
    ToggleBtn.Name = "NexusToggle"
    ToggleBtn.Size = UDim2.new(0, 50, 0, 50)
    ToggleBtn.Position = UDim2.new(0, 20, 0.5, -25)
    ToggleBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    ToggleBtn.Image = LogoImage
    ToggleBtn.Parent = NexusGui
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 25) -- Redondo
    btnCorner.Parent = ToggleBtn

    -- Frame Principal
    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "MainFrame"
    MainFrame.Size = UDim2.new(0, 500, 0, 350)
    MainFrame.Position = UDim2.new(0.5, -250, 0.5, -175)
    MainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    MainFrame.Visible = false
    MainFrame.Parent = NexusGui

    local mainCorner = Instance.new("UICorner")
    mainCorner.CornerRadius = UDim.new(0, 8)
    mainCorner.Parent = MainFrame

    -- Lógica de arrastar MainFrame
    local dragging, dragInput, dragStart, startPos
    MainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    MainFrame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    -- Topbar
    local Topbar = Instance.new("Frame")
    Topbar.Size = UDim2.new(1, 0, 0, 35)
    Topbar.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Topbar.Parent = MainFrame
    
    local topCorner = Instance.new("UICorner")
    topCorner.CornerRadius = UDim.new(0, 8)
    topCorner.Parent = Topbar

    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(1, -20, 1, 0)
    Title.Position = UDim2.new(0, 10, 0, 0)
    Title.BackgroundTransparency = 1
    Title.Text = WindowName
    Title.TextColor3 = Color3.fromRGB(255, 255, 255)
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 16
    Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.Parent = Topbar

    -- Container das abas (Botões)
    local TabContainer = Instance.new("ScrollingFrame")
    TabContainer.Size = UDim2.new(0, 130, 1, -45)
    TabContainer.Position = UDim2.new(0, 10, 0, 40)
    TabContainer.BackgroundTransparency = 1
    TabContainer.ScrollBarThickness = 0
    TabContainer.Parent = MainFrame

    local TabListLayout = Instance.new("UIListLayout")
    TabListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    TabListLayout.Padding = UDim.new(0, 5)
    TabListLayout.Parent = TabContainer

    -- Container do conteúdo (onde ficam os botões e toggles)
    local ContentContainer = Instance.new("Frame")
    ContentContainer.Size = UDim2.new(1, -160, 1, -45)
    ContentContainer.Position = UDim2.new(0, 150, 0, 40)
    ContentContainer.BackgroundTransparency = 1
    ContentContainer.Parent = MainFrame

    -- Lógica do Botão Toggle (Abre e fecha a GUI)
    ToggleBtn.MouseButton1Click:Connect(function()
        MainFrame.Visible = not MainFrame.Visible
    end)

    local WindowObj = {}
    local firstTab = true

    -- ==========================================
    -- CRIAÇÃO DE ABAS (TABS)
    -- ==========================================
    function WindowObj:CreateTab(tabName)
        local TabBtn = Instance.new("TextButton")
        TabBtn.Size = UDim2.new(1, 0, 0, 30)
        TabBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        TabBtn.Text = tabName
        TabBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
        TabBtn.Font = Enum.Font.GothamSemibold
        TabBtn.TextSize = 14
        TabBtn.Parent = TabContainer
        
        local tabCorner = Instance.new("UICorner")
        tabCorner.CornerRadius = UDim.new(0, 6)
        tabCorner.Parent = TabBtn

        local TabContent = Instance.new("ScrollingFrame")
        TabContent.Size = UDim2.new(1, 0, 1, 0)
        TabContent.BackgroundTransparency = 1
        TabContent.ScrollBarThickness = 4
        TabContent.Visible = firstTab
        TabContent.Parent = ContentContainer

        local ContentLayout = Instance.new("UIListLayout")
        ContentLayout.SortOrder = Enum.SortOrder.LayoutOrder
        ContentLayout.Padding = UDim.new(0, 8)
        ContentLayout.Parent = TabContent

        if firstTab then
            TabBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            TabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            firstTab = false
        end

        TabBtn.MouseButton1Click:Connect(function()
            for _, child in pairs(ContentContainer:GetChildren()) do
                if child:IsA("ScrollingFrame") then
                    child.Visible = false
                end
            end
            for _, child in pairs(TabContainer:GetChildren()) do
                if child:IsA("TextButton") then
                    child.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
                    child.TextColor3 = Color3.fromRGB(200, 200, 200)
                end
            end
            TabContent.Visible = true
            TabBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            TabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        end)

        local TabObj = {}

        -- ==========================================
        -- ELEMENTOS DA ABA (Botões, Toggles, Dropdowns)
        -- ==========================================
        
        -- BOTÃO
        function TabObj:CreateButton(name, callback)
            local Btn = Instance.new("TextButton")
            Btn.Size = UDim2.new(1, -10, 0, 35)
            Btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            Btn.Text = name
            Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            Btn.Font = Enum.Font.Gotham
            Btn.TextSize = 14
            Btn.Parent = TabContent
            
            Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)

            Btn.MouseButton1Click:Connect(function()
                pcall(callback)
                -- Efeito de clique
                local ts = TweenService:Create(Btn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(60, 60, 60)})
                ts:Play()
                ts.Completed:Wait()
                TweenService:Create(Btn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(40, 40, 40)}):Play()
            end)
        end

        -- TOGGLE
        function TabObj:CreateToggle(name, default, callback)
            local state = default or false
            
            local ToggleFrame = Instance.new("Frame")
            ToggleFrame.Size = UDim2.new(1, -10, 0, 35)
            ToggleFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            ToggleFrame.Parent = TabContent
            Instance.new("UICorner", ToggleFrame).CornerRadius = UDim.new(0, 6)

            local Title = Instance.new("TextLabel")
            Title.Size = UDim2.new(1, -50, 1, 0)
            Title.Position = UDim2.new(0, 10, 0, 0)
            Title.BackgroundTransparency = 1
            Title.Text = name
            Title.TextColor3 = Color3.fromRGB(255, 255, 255)
            Title.Font = Enum.Font.Gotham
            Title.TextSize = 14
            Title.TextXAlignment = Enum.TextXAlignment.Left
            Title.Parent = ToggleFrame

            local ToggleBtn = Instance.new("TextButton")
            ToggleBtn.Size = UDim2.new(0, 40, 0, 20)
            ToggleBtn.Position = UDim2.new(1, -50, 0.5, -10)
            ToggleBtn.BackgroundColor3 = state and Color3.fromRGB(0, 170, 255) or Color3.fromRGB(70, 70, 70)
            ToggleBtn.Text = ""
            ToggleBtn.Parent = ToggleFrame
            Instance.new("UICorner", ToggleBtn).CornerRadius = UDim.new(0, 10)

            local Circle = Instance.new("Frame")
            Circle.Size = UDim2.new(0, 16, 0, 16)
            Circle.Position = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
            Circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Circle.Parent = ToggleBtn
            Instance.new("UICorner", Circle).CornerRadius = UDim.new(1, 0)

            ToggleBtn.MouseButton1Click:Connect(function()
                state = not state
                pcall(callback, state)
                
                local goalColor = state and Color3.fromRGB(0, 170, 255) or Color3.fromRGB(70, 70, 70)
                local goalPos = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
                
                TweenService:Create(ToggleBtn, TweenInfo.new(0.2), {BackgroundColor3 = goalColor}):Play()
                TweenService:Create(Circle, TweenInfo.new(0.2), {Position = goalPos}):Play()
            end)
        end

        -- DROPDOWN
        function TabObj:CreateDropdown(name, options, callback)
            local isOpen = false
            
            local DropFrame = Instance.new("Frame")
            DropFrame.Size = UDim2.new(1, -10, 0, 35)
            DropFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            DropFrame.ClipsDescendants = true
            DropFrame.Parent = TabContent
            Instance.new("UICorner", DropFrame).CornerRadius = UDim.new(0, 6)

            local DropBtn = Instance.new("TextButton")
            DropBtn.Size = UDim2.new(1, 0, 0, 35)
            DropBtn.BackgroundTransparency = 1
            DropBtn.Text = name .. " ▼"
            DropBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            DropBtn.Font = Enum.Font.Gotham
            DropBtn.TextSize = 14
            DropBtn.Parent = DropFrame

            local ItemContainer = Instance.new("ScrollingFrame")
            ItemContainer.Size = UDim2.new(1, 0, 1, -35)
            ItemContainer.Position = UDim2.new(0, 0, 0, 35)
            ItemContainer.BackgroundTransparency = 1
            ItemContainer.ScrollBarThickness = 2
            ItemContainer.Parent = DropFrame

            local ItemLayout = Instance.new("UIListLayout")
            ItemLayout.SortOrder = Enum.SortOrder.LayoutOrder
            ItemLayout.Parent = ItemContainer

            -- Calcula tamanho máximo
            local maxDropdownSize = 35 + (#options * 25)
            if maxDropdownSize > 150 then maxDropdownSize = 150 end

            local function updateItems()
                for _, child in pairs(ItemContainer:GetChildren()) do
                    if child:IsA("TextButton") then child:Destroy() end
                end
                for _, option in ipairs(options) do
                    local btn = Instance.new("TextButton")
                    btn.Size = UDim2.new(1, 0, 0, 25)
                    btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
                    btn.Text = option
                    btn.TextColor3 = Color3.fromRGB(200, 200, 200)
                    btn.Font = Enum.Font.Gotham
                    btn.TextSize = 13
                    btn.Parent = ItemContainer

                    btn.MouseButton1Click:Connect(function()
                        DropBtn.Text = name .. " - " .. option .. " ▼"
                        isOpen = false
                        TweenService:Create(DropFrame, TweenInfo.new(0.2), {Size = UDim2.new(1, -10, 0, 35)}):Play()
                        pcall(callback, option)
                    end)
                end
            end
            
            updateItems()

            DropBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                local goalSize = isOpen and UDim2.new(1, -10, 0, maxDropdownSize) or UDim2.new(1, -10, 0, 35)
                TweenService:Create(DropFrame, TweenInfo.new(0.2), {Size = goalSize}):Play()
            end)

            -- Retorna objeto para permitir Refresh do Dropdown
            local DropObj = {}
            function DropObj:Refresh(newOptions)
                options = newOptions
                updateItems()
            end
            return DropObj
        end

        return TabObj
    end

    return WindowObj
end

return NexusLib
