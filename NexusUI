-- Criar a janela principal
function NexusUI.CreateWindow(title, toggleImageId)
    if NexusUI.ScreenGui then
        NexusUI.ScreenGui:Destroy()
    end

    title = title or LibraryConfig.WindowTitle
    LoadUIConfig()

    NexusUI.ScreenGui = Instance.new("ScreenGui")
    NexusUI.ScreenGui.Name = "NexusUIMain"
    NexusUI.ScreenGui.Parent = CoreGui
    NexusUI.ScreenGui.ResetOnSpawn = false
    NexusUI.ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

    -- Botão de toggle (menu)
    local toggleBtn = Instance.new("ImageButton")
    toggleBtn.Name = "ToggleButton"
    toggleBtn.Parent = NexusUI.ScreenGui
    toggleBtn.Size = UDim2.new(0, 40, 0, 40)
    toggleBtn.Position = UDim2.new(0.1, 0, 0.1, 0)
    toggleBtn.BackgroundTransparency = 1
    toggleBtn.Image = toggleImageId or "rbxassetid://108999865215827"
    toggleBtn.ImageColor3 = Color3.new(1, 1, 1)
    toggleBtn.ScaleType = Enum.ScaleType.Fit
    toggleBtn.ZIndex = 100
    AddCorner(toggleBtn, 10)
    MakeDraggable(toggleBtn, toggleBtn)

    -- Frame principal
    local mainFrame = Instance.new("Frame")
    mainFrame.Name = "MainFrame"
    mainFrame.AnchorPoint = Vector2.new(0.5, 0.5)
    mainFrame.Size = UDim2.new(0, 400, 0, 320)
    mainFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
    mainFrame.BackgroundColor3 = NexusUI.CurrentTheme.Background
    mainFrame.Parent = NexusUI.ScreenGui
    mainFrame.ClipsDescendants = true
    mainFrame.Visible = true
    AddCorner(mainFrame, 10)
    AddStroke(mainFrame, NexusUI.CurrentTheme.Accent, 2)

    local sidebar = Instance.new("Frame")
    sidebar.Name = "Sidebar"
    sidebar.Size = UDim2.new(0, 100, 1, 0)
    sidebar.BackgroundColor3 = NexusUI.CurrentTheme.Sidebar
    sidebar.Parent = mainFrame
    AddCorner(sidebar, 10)
    MakeDraggable(mainFrame, sidebar)

    local content = Instance.new("Frame")
    content.Name = "ContentContainer"
    content.Size = UDim2.new(1, -110, 1, -20)
    content.Position = UDim2.new(0, 110, 0, 10)
    content.BackgroundTransparency = 1
    content.Parent = mainFrame

    local titleLabel = Instance.new("TextLabel")
    titleLabel.Name = "TitleLabel"
    titleLabel.Parent = sidebar
    titleLabel.Size = UDim2.new(1, 0, 0, 30)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = title
    titleLabel.TextColor3 = NexusUI.CurrentTheme.Accent
    titleLabel.Font = Enum.Font.GothamBlack
    titleLabel.TextSize = 14
    titleLabel.LayoutOrder = 0

    -- Restaurar posições salvas
    if NexusUI.SavedPositions["MainFrame"] then
        local p = NexusUI.SavedPositions["MainFrame"]
        mainFrame.Position = UDim2.new(p[1], p[2], p[3], p[4])
    end
    if NexusUI.SavedPositions["ToggleButton"] then
        local p = NexusUI.SavedPositions["ToggleButton"]
        toggleBtn.Position = UDim2.new(p[1], p[2], p[3], p[4])
    end

    NexusUI.MainFrame = mainFrame
    NexusUI.Sidebar = sidebar
    NexusUI.ContentContainer = content
    NexusUI.TitleLabel = titleLabel
    NexusUI.ToggleButton = toggleBtn
    NexusUI.Tabs = {}

    toggleBtn.MouseButton1Click:Connect(function()
        PlayClickSound()
        mainFrame.Visible = not mainFrame.Visible
        if mainFrame.Visible then
            mainFrame.Size = UDim2.new(0, 0, 0, 0)
            mainFrame.BackgroundTransparency = 1
            TweenService:Create(mainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                Size = UDim2.new(0, 400, 0, 320),
                BackgroundTransparency = 0
            }):Play()
        end
    end)

    -- Animar abertura
    mainFrame.Size = UDim2.new(0, 0, 0, 0)
    TweenService:Create(mainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quart), {
        Size = UDim2.new(0, 400, 0, 320)
    }):Play()

    ApplyThemeToUI()
    return NexusUI
end

-- Criar uma nova aba
function NexusUI.CreateTab(name)
    if not NexusUI.MainFrame then
        error("CreateWindow must be called before CreateTab")
    end
    local tabBtn = Instance.new("TextButton")
    tabBtn.Size = UDim2.new(1, -10, 0, 30)
    tabBtn.Position = UDim2.new(0, 5, 0, 50 + (#NexusUI.Tabs * 35))
    tabBtn.BackgroundColor3 = NexusUI.CurrentTheme.Background
    tabBtn.Text = name
    tabBtn.Font = Enum.Font.GothamSemibold
    tabBtn.TextColor3 = NexusUI.CurrentTheme.TextDim
    tabBtn.TextSize = 12
    tabBtn.AutoButtonColor = false
    tabBtn.Parent = NexusUI.Sidebar
    AddCorner(tabBtn, 6)

    local tabFrame = Instance.new("ScrollingFrame")
    tabFrame.Size = UDim2.new(1, 0, 1, 0)
    tabFrame.BackgroundTransparency = 1
    tabFrame.ScrollBarThickness = 2
    tabFrame.ScrollBarImageColor3 = NexusUI.CurrentTheme.Accent
    tabFrame.Visible = false
    tabFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y
    tabFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    tabFrame.Parent = NexusUI.ContentContainer

    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 6)
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Parent = tabFrame

    local padding = Instance.new("UIPadding")
    padding.PaddingTop = UDim.new(0, 5)
    padding.PaddingLeft = UDim.new(0, 5)
    padding.PaddingBottom = UDim.new(0, 5)
    padding.Parent = tabFrame

    table.insert(NexusUI.Tabs, {Btn = tabBtn, Frame = tabFrame})

    tabBtn.MouseButton1Click:Connect(function()
        PlayClickSound()
        for _, t in ipairs(NexusUI.Tabs) do
            t.Frame.Visible = false
            TweenService:Create(t.Btn, TweenInfo.new(0.3), {
                TextColor3 = NexusUI.CurrentTheme.TextDim,
                BackgroundColor3 = NexusUI.CurrentTheme.Background
            }):Play()
        end
        tabFrame.Visible = true
        TweenService:Create(tabBtn, TweenInfo.new(0.3), {
            TextColor3 = NexusUI.CurrentTheme.Text,
            BackgroundColor3 = NexusUI.CurrentTheme.AccentDark
        }):Play()
    end)

    return tabFrame
end

