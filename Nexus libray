-- UNIVERSAL FLOATING BUTTONS (Com Estilos "Large", "Small", "Ghost", "Success")
-- ==============================================================================
function NexusLibrary:CreateFloatingButton(Text, Style, Position, ThemeName, SaveKey, Callback)
    local Theme = NexusLibrary.Themes[ThemeName or "Original"]
    local ScreenGui = Instance.new("ScreenGui", CoreGui)
    ScreenGui.IgnoreGuiInset = true; ScreenGui.ResetOnSpawn = false

    local Frame = Instance.new("Frame", ScreenGui)
    Frame.Position = Position or UDim2.new(0.5, 0, 0.5, 0)
    Frame.BackgroundColor3 = Theme.Background; Frame.BackgroundTransparency = 0.2
    Frame.Visible = true; Frame.BorderSizePixel = 0
    
    local Button = Instance.new("TextButton", Frame)
    Button.Size = UDim2.new(1, 0, 1, 0); Button.BackgroundTransparency = 1
    Button.Text = Text; Button.Font = Enum.Font.GothamBold; Button.AutoButtonColor = false

    local StrokeObj = Stroke(Frame, Theme.Accent, 2)
    MakeDraggable(Frame)
    if SaveKey then NexusLibrary.SavedElements[SaveKey] = Frame end

    if Style == "Large" then
        Frame.Size = UDim2.new(0, 220, 0, 80); Button.TextSize = 24; Button.TextColor3 = Theme.Accent; Corner(Frame, 10)
        local Gradient = Instance.new("UIGradient", StrokeObj)
        Gradient.Color = ColorSequence.new{ColorSequenceKeypoint.new(0.00, Theme.Accent), ColorSequenceKeypoint.new(0.50, Color3.fromRGB(255, 255, 255)), ColorSequenceKeypoint.new(1.00, Theme.Accent)}
        task.spawn(function()
            while Frame.Parent do
                if Frame.Visible then
                    Gradient.Rotation = (Gradient.Rotation + 2) % 360
                    Button.TextColor3 = Theme.Accent:Lerp(Color3.fromRGB(255, 255, 255), 0.5 + 0.5 * math.sin(tick() * math.pi))
                end
                task.wait(0.01)
            end
        end)
    else
        Frame.Size = UDim2.new(0, 100, 0, 30); Button.TextSize = 12; Corner(Frame, 6)
        if Style == "Small" then StrokeObj.Color = Theme.Accent; Button.TextColor3 = Theme.Accent
        elseif Style == "Ghost" then StrokeObj.Color = Theme.Ghost; Button.TextColor3 = Theme.Ghost
        elseif Style == "Success" then StrokeObj.Color = Color3.fromRGB(0, 255, 150); Button.TextColor3 = Color3.fromRGB(0, 255, 150) end

        task.spawn(function()
            while Frame.Parent do
                if Frame.Visible then
                    TweenService:Create(StrokeObj, TweenInfo.new(0.8, Enum.EasingStyle.Sine), {Transparency = 0.4}):Play()
                    task.wait(0.8)
                    TweenService:Create(StrokeObj, TweenInfo.new(0.8, Enum.EasingStyle.Sine), {Transparency = 0}):Play()
                    task.wait(0.8)
                else task.wait(1) end
            end
        end)
    end

    if Callback then Button.MouseButton1Click:Connect(function() NexusLibrary:PlaySound(); Callback() end) end

    -- Funções para alterar dinamicamente!
    local FloatingAPI = {}
    function FloatingAPI:SetVisible(state) Frame.Visible = state end
    function FloatingAPI:SetText(newText) Button.Text = newText end
    function FloatingAPI:SetColor(color) Button.TextColor3 = color; StrokeObj.Color = color end
    return FloatingAPI
end

