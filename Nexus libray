            local DropdownFrame = Instance.new("Frame", TabFrame)
            DropdownFrame.Size = UDim2.new(1, 0, 0, 32); DropdownFrame.BackgroundColor3 = currentTheme.ItemBG; Corner(DropdownFrame, 6)
            local Label = Instance.new("TextLabel", DropdownFrame)
            Label.Size = UDim2.new(0.5, 0, 1, 0); Label.Position = UDim2.new(0, 8, 0, 0); Label.BackgroundTransparency = 1; Label.Text = Text; Label.TextColor3 = currentTheme.Text; Label.Font = Enum.Font.GothamSemibold; Label.TextSize = 12; Label.TextXAlignment = Enum.TextXAlignment.Left
