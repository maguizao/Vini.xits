-- SAVE CONFIG
-- ==============================================================================
function NexusLibrary:SavePositions(FileName)
    if not writefile then return end
    local DataToSave = {}
    for Key, Frame in pairs(NexusLibrary.SavedElements) do
        if Frame and Frame.Position then
            DataToSave[Key] = { XScale = Frame.Position.X.Scale, XOffset = Frame.Position.X.Offset, YScale = Frame.Position.Y.Scale, YOffset = Frame.Position.Y.Offset }
        end
    end
    local success, encoded = pcall(function() return HttpService:JSONEncode(DataToSave) end)
    if success then writefile(FileName .. ".json", encoded); NexusLibrary:Notify("Sucesso!", "Posições salvas!", 3) end
end

function NexusLibrary:LoadPositions(FileName)
    if not readfile or not isfile or not isfile(FileName .. ".json") then return end
    local success, data = pcall(function() return HttpService:JSONDecode(readfile(FileName .. ".json")) end)
    if success and type(data) == "table" then
        for Key, PosData in pairs(data) do
            if NexusLibrary.SavedElements[Key] then NexusLibrary.SavedElements[Key].Position = UDim2.new(PosData.XScale, PosData.XOffset, PosData.YScale, PosData.YOffset) end
        end
    end
end

return NexusLibrary
